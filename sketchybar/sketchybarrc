apple=(
  script="$PLUGIN_DIR/apple.sh"
  click_script="$POPUP_CLICK_SCRIPT"
  popup.align=left
  popup.height=32
  popup.y_offset=8
  label="$APPLE"
  label.padding_right=15
  label.padding_left=15
  background.color="$TOKYO_BG"
  background.height=19
  background.corner_radius=10
  background.padding_left=3
  background.padding_right=3
)

sketchybar --add item apple left \
  --set apple "${apple[@]!}" \
  --subscribe apple mouse.entered mouse.exited

space=(
  label.drawing=off
  width=30
  icon.font="SF Pro:Bold:14.0"
  icon.width=30
  icon.align=center
  icon.padding_left=0
  icon.padding_right=0
  background.color="$TRANSPARENT"
  background.height=18
  background.corner_radius=9
  background.border_width=1
  background.border_color="$TRANSPARENT"
)

declare -a spacesArray=()
for i in "${!SPACE_GHOSTS[@]}"; do
  sid=$(($i + 1))

  if [[ $sid -eq $ACTIVE_SPACE ]]; then
    CURRENT_ICON=$PACMAN
    CURRENT_COLOR=$PACMAN_WHITE
    CURRENT_BG=$TRANSPARENT
    CURRENT_BORDER=$TRANSPARENT
  else
    CURRENT_ICON=${SPACE_GHOSTS["$i"]}
    CURRENT_COLOR=${SPACE_GHOST_COLORS["$i"]}
    CURRENT_BG=$TRANSPARENT
    CURRENT_BORDER=$TRANSPARENT
  fi

  spacesArray+=("space.$sid")

  sketchybar --add space space.$sid left \
    --set space.$sid space=$sid \
    icon="$CURRENT_ICON" \
    icon.color="$CURRENT_COLOR" \
    background.color="$CURRENT_BG" \
    background.border_color="$CURRENT_BORDER" \
    click_script="yabai -m space --focus $sid" \
    script="$PLUGIN_DIR/space_hover.sh" \
    "${space[@]}" \
    --subscribe "space.$sid" mouse.entered mouse.exited
done

sketchybar --add item space_animator left \
  --set space_animator drawing=off updates=on script="$PLUGIN_DIR/spaces.sh" \
  --subscribe space_animator space_change

front_app=(
  script="$PLUGIN_DIR/front_app.sh"
  update_freq=5
  updates=on
  scroll_texts=off
  padding_left=8
  icon="Desktop"
  icon.font="SF Pro:Semibold:11.0"
  icon.color="$TOKYO_BLUE"
  icon.padding_left=11
  icon.padding_right=11
  label=""
  label.font="SF Pro:Medium:11.0"
  label.color="$SUBTEXT"
  label.max_chars=38
  label.padding_left=0
  label.padding_right=0
  background.color="$TOKYO_SURFACE"
  background.height=25
  background.corner_radius=9
  background.border_color="$TOKYO_BORDER"
  background.border_width=2
)

sketchybar --add item front_app left \
  --set front_app "${front_app[@]!}" \
  --subscribe front_app front_app_switched space_change window_context_changed

brackets=(
  background.color="$TOKYO_SURFACE"
  background.height=25
  background.corner_radius=10
  background.border_color="$TOKYO_BORDER"
  background.border_width=2
)

sketchybar --add bracket status time date wifi battery volume_icon right \
  --set status "${brackets[@]!}"

