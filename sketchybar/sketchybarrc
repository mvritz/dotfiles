source "$HOME/.config/sketchybar/colors.sh"
source "$HOME/.config/sketchybar/icons.sh"
source "$HOME/.config/sketchybar/environment.sh"

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"
POPUP_CLICK_SCRIPT="$PLUGIN_DIR/popup_toggle.sh"
ACTIVE_SPACE=$(yabai -m query --spaces --space | jq '.index')
rm -f "${TMPDIR:-/tmp}/sketchybar-pacman/front-context"

bar=(
  height=30
  margin=5
  corner_radius=10
  position=top
  color="$TRANSPARENT"
  border_color="$TOKYO_BORDER"
  y_offset=4
  sticky=off
)

sketchybar --bar "${bar[@]!}"

defaults=(
  updates=when_shown
  icon.drawing=on
  icon.font="SF Pro:Regular:12.0"
  icon.color="$WHITE"
  label.font="SF Pro:Regular:12.0"
  label.drawing=on
  label.color="$WHITE"
  popup.background.color="$TOKYO_POPUP_BG"
  popup.background.corner_radius=10
  popup.background.border_width=1
  popup.background.border_color="$TOKYO_POPUP_BORDER"
  popup.background.padding_left=7
  popup.background.padding_right=7
  popup.background.shadow.drawing=on
  popup.background.shadow.color="$TOKYO_POPUP_SHADOW"
  popup.background.shadow.angle=270
  popup.background.shadow.distance=6
  popup.blur_radius=36
)

sketchybar --default "${defaults[@]!}"
sketchybar --add event window_context_changed

time=(
  update_freq=1
  script="$PLUGIN_DIR/time.sh"
  click_script="$POPUP_CLICK_SCRIPT"
  popup.align=right
  popup.height=32
  popup.y_offset=8
  label.font="SF Pro:Bold:12.0"
  label.padding_left=20
  label.padding_right=15
  background.corner_radius=10
  background.color="$TOKYO_BG"
  background.height=19
  background.padding_left=-10
  background.padding_right=3
  background.border_color="$TOKYO_BORDER"
)

sketchybar --add item time right \
  --set time "${time[@]!}" \
  --subscribe time system_woke mouse.entered mouse.exited

date=(
  update_freq=30
  script="$PLUGIN_DIR/date.sh"
  label.padding_left=15
  background.color="$TOKYO_BG"
  background.height=19
  background.corner_radius=10
)

sketchybar --add item date right \
  --set date "${date[@]!}" \
  --subscribe date system_woke

wifi=(
  script="$PLUGIN_DIR/wifi.sh"
  click_script="$POPUP_CLICK_SCRIPT"
  popup.align=center
  popup.height=32
  popup.y_offset=8
  width=33
  label.width=33
  label.align=center
  label.padding_right=0
  update_freq=60
)

rm -f /tmp/sketchybar_wifi
sketchybar --add item wifi right \
  --set wifi "${wifi[@]!}" \
  --subscribe wifi system_woke mouse.entered mouse.exited

battery=(
  script="$PLUGIN_DIR/battery.sh"
  update_freq=120
  updates=on
  click_script="$POPUP_CLICK_SCRIPT"
  popup.align=center
  popup.height=32
  popup.y_offset=8
  width=33
  icon.width=33
  icon.align=center
  label.padding_left=0
)

sketchybar --add item battery right \
  --set battery "${battery[@]!}" \
  --subscribe battery power_source_change system_woke mouse.entered mouse.exited

volume_icon=(
  script="$PLUGIN_DIR/volume.sh"
  click_script="$PLUGIN_DIR/volume_click.sh"
  label="$VOLUME_66"
  popup.align=center
  popup.height=32
  popup.y_offset=8
  width=33
  label.width=33
  label.align=center
  label.padding_right=0
  label.padding_left=0
)

sketchybar --add item volume_icon right \
  --set volume_icon "${volume_icon[@]!}" \
  --subscribe volume_icon volume_change mouse.entered mouse.exited

weather=(
  background.color="$TOKYO_SURFACE"
  background.height=25
  background.corner_radius=10
  background.padding_right=10
  background.border_color="$TOKYO_BORDER"
  background.border_width=2
  icon.padding_left=15
  icon.padding_right=15
  update_freq=900
  script="$PLUGIN_DIR/weather.sh"
  click_script="$POPUP_CLICK_SCRIPT"
  popup.align=center
  popup.height=34
  popup.y_offset=8
)

sketchybar --add item weather right \
  --set weather "${weather[@]!}" \
  --subscribe weather mouse.entered mouse.exited

