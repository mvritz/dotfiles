#!/bin/bash

MAIN_DISPLAY=$(system_profiler SPDisplaysDataType | grep -B 3 'Main Display:' | awk '/Display Type/ {print $3}')

config=(
  mouse_follows_focus on
  focus_follows_mouse autoraise
  window_origin_display default
  window_placement second_child
  window_zoom_persist off
  window_shadow float
  window_animation_duration 0.18
  window_animation_easing ease_out_expo
  window_opacity_duration 0.12
  active_window_opacity 1.0
  normal_window_opacity 0.94
  window_opacity on
  insert_feedback_color 0xffFF9E64
  split_ratio 0.50
  split_type auto
  auto_balance off
  left_padding 8
  right_padding 8
  top_padding 8
  bottom_padding 8
  window_gap 12
  layout bsp
  mouse_modifier cmd
  mouse_action1 move
  mouse_action2 resize
  mouse_drop_action swap
)

yabai -m config "${config[@]}"

"$HOME/.config/borders/bordersrc" &

# The sudoers rule is hash-bound to this exact binary for safety.
yabai -m signal --add event=dock_did_restart action="sudo -n /opt/homebrew/bin/yabai --load-sa"
sudo -n /opt/homebrew/bin/yabai --load-sa

if [[ $MAIN_DISPLAY = "Built-in" ]]; then
    yabai -m config external_bar main:7:0
else
    yabai -m config external_bar main:35:0
fi

yabai -m rule --add app="^System Settings" sticky=on manage=off
yabai -m rule --add app="^Finder" sticky=on manage=off
yabai -m rule --add app="^WhatsApp" sticky=on manage=off
yabai -m rule --add app="^FaceTime" sticky=on manage=off
yabai -m rule --add app="^Raycast" sticky=on manage=off
yabai -m rule --add app="^Music" sticky=on manage=off
yabai -m rule --add app="^Reminders" sticky=on manage=off
yabai -m rule --add app="^Simulator" sticky=on manage=off
yabai -m rule --add app="^zoom.us" sticky=off manage=off

yabai -m signal --add event=window_focused action="/opt/homebrew/bin/sketchybar --trigger window_context_changed"
yabai -m signal --add event=window_title_changed action="/opt/homebrew/bin/sketchybar --trigger window_context_changed"
